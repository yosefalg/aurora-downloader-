{
  "name": "aurora-downloader",
  "version": "3.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "format": "prettier --write .",
    "test": "jest --coverage",
    "test:integration": "jest --config jest.integration.config.js --coverage",
    "test:e2e": "playwright test",
    "test:load": "ts-node tests/load/download.load.ts",
    "worker": "ts-node --project tsconfig.worker.json src/lib/queue/worker.ts",
    "scheduler": "ts-node --project tsconfig.worker.json src/lib/queue/scheduler.ts",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate deploy",
    "db:seed": "ts-node scripts/seed.js",
    "clean": "rm -rf .next node_modules dist coverage",
    "security:scan": "npm audit && npx audit-ci --moderate",
    "security:fix": "npm audit fix",
    "db:backup": "bash scripts/backups/backup.sh",
    "db:restore": "bash scripts/backups/restore.sh",
    "k8s:apply": "kubectl apply -k k8s/overlays/production",
    "k8s:delete": "kubectl delete -k k8s/overlays/production",
    "tf:init": "cd terraform && terraform init",
    "tf:plan": "cd terraform && terraform plan",
    "tf:apply": "cd terraform && terraform apply",
    "ansible:deploy": "ansible-playbook -i ansible/inventory ansible/playbook.yml"
  },
  "dependencies": {
    "@prisma/client": "5.8.0",
    "@upstash/ratelimit": "0.4.4",
    "@upstash/redis": "1.25.0",
    "bullmq": "4.16.0",
    "clsx": "2.1.0",
    "compression": "1.7.4",
    "framer-motion": "10.18.0",
    "ioredis": "5.3.2",
    "lucide-react": "0.303.0",
    "next": "14.1.0",
    "next-themes": "0.2.1",
    "prisma": "5.8.0",
    "prom-client": "15.0.0",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "react-hot-toast": "2.4.1",
    "tailwind-merge": "2.2.0",
    "uuid": "9.0.1",
    "winston": "3.11.0",
    "zod": "3.22.4",
    "zustand": "4.5.0",
    "@aws-sdk/client-s3": "^3.450.0",
    "@aws-sdk/s3-request-presigner": "^3.450.0",
    "@sentry/nextjs": "^7.91.0",
    "bcryptjs": "^2.4.3",
    "jsonwebtoken": "^9.0.2",
    "nodemailer": "^6.9.7",
    "stripe": "^14.9.0",
    "web-push": "^3.6.6"
  },
  "devDependencies": {
    "@playwright/test": "1.40.1",
    "@types/compression": "1.7.5",
    "@types/jest": "29.5.11",
    "@types/node": "20.10.6",
    "@types/react": "18.2.46",
    "@types/react-dom": "18.2.18",
    "@types/uuid": "9.0.7",
    "@types/winston": "2.4.4",
    "@typescript-eslint/eslint-plugin": "6.17.0",
    "@typescript-eslint/parser": "6.17.0",
    "autoprefixer": "10.4.16",
    "eslint": "8.56.0",
    "eslint-config-next": "14.1.0",
    "jest": "29.7.0",
    "jest-environment-jsdom": "29.7.0",
    "postcss": "8.4.33",
    "prettier": "3.1.1",
    "tailwindcss": "3.4.0",
    "ts-jest": "29.1.1",
    "ts-node": "10.9.2",
    "typescript": "5.3.3",
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/nodemailer": "^6.4.14",
    "@types/web-push": "^3.6.3",
    "audit-ci": "^6.6.1"
  }
}